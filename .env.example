# ============================================================
#  ENVIRONMENT VARIABLES - Chandra Color Shoppee WhatsApp Bot
# ============================================================
#  This is an EXAMPLE file. You do NOT edit this file directly.
#  Instead, copy these names into your hosting service's
#  "Environment Variables" settings (see SETUP_GUIDE.md, Step 4).
# ============================================================

# Your Anthropic (Claude) API key.
# Get it from: https://console.anthropic.com  ->  Settings  ->  API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The port the server runs on. Most hosts set this automatically.
# Leave it as 3000 if your host asks for a value.
PORT=3000
